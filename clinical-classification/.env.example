# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Astra DB Configuration
ASTRA_DB_APPLICATION_TOKEN=your_astra_db_token_here
ASTRA_DB_API_ENDPOINT=your_astra_db_endpoint_here

# Example format:
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx
# ASTRA_DB_APPLICATION_TOKEN=AstraCS:xxxxxxxxxxxxx
# ASTRA_DB_API_ENDPOINT=https://xxxxx-us-east-2.apps.astra.datastax.com
